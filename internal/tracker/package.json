{
  "name": "@kit/tracker",
  "version": "0.0.0",
  "description": "基于适配器模式的前端埋点数据采集组件包",
  "author": "<sunweijie@able-elec.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "test": "vitest --run",
    "build": "pnpm run clean && tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vue": "^3.5.31",
    "vue-router": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@types/node": "*",
    "eslint": "*",
    "rimraf": "*",
    "tsup": "*",
    "vue": "*",
    "vue-router": "*",
    "vitest": "*"
  }
}
