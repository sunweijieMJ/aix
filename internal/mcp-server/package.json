{
  "name": "@aix/mcp-server",
  "version": "0.0.4",
  "description": "MCP server for component library",
  "author": "<sunweijie@able-elec.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aix-mcp-server": "./dist/cli.js"
  },
  "keywords": [
    "mcp-server",
    "component-library"
  ],
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && tsdown --config-loader tsx",
    "clean": "rimraf dist",
    "extract": "rimraf data && tsx src/cli.ts extract --packages=../../packages",
    "postinstall": "echo '📦 AIX Components MCP Server installed successfully! Use: npx @aix/mcp-server --help'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "typescript": "catalog:",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
