{
  "name": "@aix/server",
  "version": "0.0.0",
  "private": true,
  "description": "Lightweight Hono API server template",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx watch src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "npm run clean && tsup src/index.ts --format esm --dts",
    "prod": "node dist/index.js",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "adm-zip": "^0.5.17",
    "@libsql/client": "^0.17.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "*",
    "@vitest/coverage-v8": "*",
    "drizzle-kit": "^0.31.10",
    "eslint": "*",
    "prettier": "*",
    "rimraf": "*",
    "tsup": "*",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
