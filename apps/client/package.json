{
  "name": "@aix/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AIX 组件库示例项目 - 模拟外部业务项目联调场景",
  "scripts": {
    "dev": "cross-env VITE_LINK_MODE=source vite",
    "build": "vue-tsc --noEmit && vite build",
    "dev:yalc": "cross-env VITE_LINK_MODE=yalc vite",
    "add:yalc": "tsx scripts/add-yalc.ts",
    "remove:yalc": "tsx scripts/remove-yalc.ts",
    "lint:script": "eslint . --max-warnings 0",
    "lint:style": "stylelint 'src/**/*.{css,scss,vue}' --max-warnings 0 --allow-empty-input",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "pnpm run lint:script && pnpm run lint:style",
    "i18n": "tsx ../../kit/i18n-tools/src/cli.ts --config ./i18n.config.ts",
    "visual-test": "visual-test test",
    "visual-test:update": "visual-test test --update",
    "visual-test:ci": "visual-test test --ci"
  },
  "dependencies": {
    "@aix/hooks": "workspace:^",
    "@aix/rich-text-editor": "workspace:^",
    "@aix/theme": "workspace:^",
    "vue": "catalog:",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/i18n-tools": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/stylelint-config": "workspace:^",
    "@kit/visual-testing": "workspace:^",
    "@vitejs/plugin-vue": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "playwright": "^1.61.1",
    "stylelint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  }
}
