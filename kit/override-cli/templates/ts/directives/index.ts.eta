 * @example
 * ```ts
 * return {
 *   'lab-access': {
 *     mounted(el, binding) {
 *       // 权限控制逻辑
 *     },
 *   },
 * };
 * ```
 */
export function getCustomDirectives(): Record<string, Directive> {
  return {
    // 按需注册定制指令
  };
}
