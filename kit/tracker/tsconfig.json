{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@kit/typescript-config/base-app.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2020",
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "__test__", "**/*.test.ts"]
}
