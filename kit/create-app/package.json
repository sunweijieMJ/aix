{
  "name": "@kit/create-app",
  "version": "0.1.0",
  "description": "前端项目脚手架工具（含 Override 定制化管理）",
  "author": "<sunweijie@able-elec.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-app": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates-override"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && tsup",
    "clean": "rimraf dist",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "giget": "^1.2.4",
    "jiti": "^2.4.2",
    "picocolors": "^1.1.1",
    "semver": "^7.7.1",
    "validate-npm-package-name": "^6.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "*",
    "@types/semver": "^7.7.1",
    "@types/validate-npm-package-name": "^4.0.2",
    "eslint": "*",
    "rimraf": "*",
    "tsup": "*",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
