{
  "name": "@kit/create-app",
  "version": "0.1.0",
  "description": "前端项目脚手架工具（含 Override 定制化管理）",
  "author": "<sunweijie@able-elec.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "create-app": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates-override"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && tsdown --config-loader tsx",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5",
    "giget": "^3.3.0",
    "jiti": "^2.7.0",
    "picocolors": "^1.1.1",
    "semver": "^7.8.4",
    "validate-npm-package-name": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "catalog:",
    "@types/semver": "^7.7.1",
    "@types/validate-npm-package-name": "^4.0.2",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
