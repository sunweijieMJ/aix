{
  "name": "@kit/i18n-tools",
  "version": "0.0.22",
  "description": "I18n automation tools for Vue/React projects",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "i18n-tools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "build": "pnpm run clean && tsdown --config-loader tsx",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vue/compiler-dom": "^3.5.38",
    "@vue/compiler-sfc": "^3.5.38",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "inquirer": "^14.0.2",
    "jiti": "^2.7.0",
    "openai": "^6.42.0",
    "picomatch": "^4.0.4",
    "typescript": "catalog:",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "@types/inquirer": "^9.0.10",
    "@types/node": "catalog:",
    "@types/picomatch": "^4.0.3",
    "@types/yargs": "^17.0.35",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:"
  }
}
