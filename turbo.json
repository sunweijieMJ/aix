{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    "internal/typescript-config/*.json",
    "tsconfig.json",
    "typings/**/*.d.ts",
    "pnpm-workspace.yaml"
  ],
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,vue}",
        "src/**/*.{css,scss,sass,less}",
        "src/**/*.{json,md}",
        "typings/**/*.d.ts",
        "assets/**",
        "scripts/**",
        "package.json",
        "tsconfig*.json",
        "rollup.config.js",
        "../../rollup.config.js",
        "tsdown.config.ts",
        "../../tsdown.config.ts"
      ],
      "outputs": ["**/dist/**", "**/lib/**", "**/es/**"],
      "cache": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,vue}",
        "typings/**/*.d.ts",
        "stories/**/*.{ts,tsx,vue}",
        "__test__/**/*.{ts,tsx,vue}",
        "*.config.ts",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [],
      "cache": true
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../eslint.config.ts",
        "../../internal/eslint-config/**/*.js",
        "../../internal/stylelint-config/*.js",
        "../../tsconfig.json"
      ],
      "outputs": [],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,vue}",
        "__test__/**/*.{ts,tsx,js,jsx,vue}",
        "vitest.config.ts",
        "../../internal/vitest-config/*.{js,ts}",
        "package.json"
      ],
      "outputs": [],
      "cache": true
    }
  }
}
