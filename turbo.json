{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "internal/typescript-config/*.json", "tsconfig.json"],
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,vue}",
        "src/**/*.{css,scss,sass,less}",
        "src/**/*.{json,md}",
        "package.json",
        "tsconfig*.json",
        "rollup.config.js",
        "../../rollup.config.js"
      ],
      "outputs": ["**/dist/**", "**/lib/**", "**/es/**"],
      "cache": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,vue}",
        "typings/**/*.d.ts",
        "stories/**/*.{ts,tsx,vue}",
        "__test__/**/*.{ts,tsx,vue}",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [],
      "cache": true
    },
    "lint": {
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,vue}",
        "eslint.config.ts",
        "../../eslint.config.ts",
        "../../internal/eslint-config/**/*.js",
        "package.json",
        "tsconfig.json",
        "../../tsconfig.json"
      ],
      "outputs": [],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "build:generate": {
      "inputs": ["assets/**/*.svg", "scripts/**/*.ts", "package.json"],
      "outputs": ["src/**"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,vue}",
        "__test__/**/*.{ts,tsx,js,jsx,vue}",
        "vitest.config.ts",
        "../../internal/vitest-config/*.{js,ts}"
      ],
      "outputs": [],
      "cache": true
    }
  }
}
