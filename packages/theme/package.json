{
  "name": "@aix/theme",
  "version": "0.0.1",
  "description": "AIX Design System - Theme System with CSS Variables & TypeScript API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/vars/index.css",
  "sideEffects": [
    "*.css",
    "dist/**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./style": "./dist/vars/index.css",
    "./vars": "./dist/vars/index.css",
    "./vars/base": "./dist/vars/base-tokens.css",
    "./vars/light": "./dist/vars/light.css",
    "./vars/dark": "./dist/vars/dark.css",
    "./vars/compat": "./dist/vars/index.compat.css",
    "./package.json": "./package.json"
  },
  "bin": {
    "aix-theme-export": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "gen:css": "tsx scripts/gen-css.ts",
    "dev": "pnpm run gen:css && rollup -c -w",
    "lint:script": "eslint . --max-warnings 0",
    "lint:style": "stylelint 'src/**/*.{css,scss,vue}' --max-warnings 0 --allow-empty-input",
    "lint": "pnpm run lint:script && pnpm run lint:style",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && pnpm run gen:css && pnpm run build:types && rollup -c",
    "build:types": "tsc --emitDeclarationOnly --outDir dist -p tsconfig.build.json",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/stylelint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "postcss": "catalog:",
    "postcss-import": "^16.1.1",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-esbuild": "catalog:",
    "rollup-plugin-postcss": "catalog:",
    "stylelint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
