{
  "name": "@aix/ai-chat",
  "version": "0.0.1",
  "description": "A Vue 3 AI chat component package",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./es/index.js",
  "types": "./es/index.d.ts",
  "style": "./es/index.css",
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.sass"
  ],
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.cjs"
    },
    "./es/*": "./es/*",
    "./lib/*": "./lib/*",
    "./style": "./es/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "lib",
    "es"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "lint:script": "eslint . --max-warnings 0",
    "lint:style": "stylelint 'src/**/*.{css,scss,vue}' --max-warnings 0 --allow-empty-input",
    "lint": "pnpm run lint:script && pnpm run lint:style",
    "test": "vitest --run",
    "type-check": "vue-tsc --noEmit -p tsconfig.json && pnpm type-check:stories",
    "type-check:stories": "vue-tsc --noEmit -p tsconfig.stories-check.json",
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:types",
    "build:js": "rollup -c",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir es",
    "clean": "rimraf dist lib es tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aix/hooks": "workspace:^",
    "@aix/icons": "workspace:^",
    "@aix/theme": "workspace:^",
    "virtua": "^0.39.0"
  },
  "optionalDependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "dompurify": "^3.4.8",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/stylelint-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "@types/markdown-it": "*",
    "@vue/test-utils": "*",
    "eslint": "*",
    "jsdom": "*",
    "rimraf": "*",
    "stylelint": "*",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*",
    "vue-tsc": "*"
  }
}
