{
  "name": "@aix/rich-text-editor",
  "version": "0.0.7",
  "description": "A Vue 3 RichTextEditor component for AIX component library",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./es/index.js",
  "types": "./es/index.d.ts",
  "style": "./es/index.css",
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.sass"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./es/index.d.ts",
        "default": "./es/index.js"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./es/*": "./es/*",
    "./lib/*": "./lib/*",
    "./style": "./es/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "lint:script": "eslint . --max-warnings 0",
    "lint:style": "stylelint 'src/**/*.{css,scss,vue}' --max-warnings 0 --allow-empty-input",
    "lint": "pnpm run lint:script && pnpm run lint:style",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && pnpm run build:types && pnpm run build:js",
    "build:js": "rollup -c",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir es -p tsconfig.build.json",
    "clean": "rimraf dist lib es tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aix/hooks": "workspace:^",
    "@aix/icons": "workspace:^",
    "@aix/popper": "workspace:^",
    "@aix/theme": "workspace:^",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-character-count": "^3.26.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-font-family": "^3.26.1",
    "@tiptap/extension-font-size": "3.0.0-next.3",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-mention": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-subscript": "^3.26.1",
    "@tiptap/extension-superscript": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/suggestion": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "tiptap-markdown": "^0.9.0"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/stylelint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "stylelint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:"
  }
}
