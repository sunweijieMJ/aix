{
  "name": "@aix/icons",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./es/index.js",
  "types": "./es/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./es/index.d.ts",
        "default": "./es/index.js"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./*": {
      "types": "./es/*.d.ts",
      "import": "./es/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "es",
    "lib"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "lint": "eslint . --max-warnings 0",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build:generate": "tsx scripts/generate.ts",
    "build:js": "rollup -c",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir es -p tsconfig.build.json",
    "build": "pnpm run clean && pnpm run build:generate && pnpm run build:types && pnpm run build:js",
    "clean": "rimraf dist es lib src tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "eslint": "catalog:",
    "glob": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
