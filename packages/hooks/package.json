{
  "name": "@aix/hooks",
  "version": "0.0.1",
  "description": "AIX Component Library - Utility Hooks Collection",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./es/index.js",
  "types": "./es/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./es/index.d.ts",
        "default": "./es/index.js"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./use-locale": {
      "import": {
        "types": "./es/use-locale/index.d.ts",
        "default": "./es/use-locale/index.js"
      },
      "require": {
        "types": "./lib/use-locale/index.d.cts",
        "default": "./lib/use-locale/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "lint": "eslint . --max-warnings 0",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && pnpm run build:types && pnpm run build:js",
    "build:js": "rollup -c",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist es lib tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/typescript-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "license": "MIT"
}
