{
  "name": "@aix/hooks",
  "version": "0.0.1",
  "description": "AIX Component Library - Utility Hooks Collection",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./es/index.js",
  "types": "./es/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.cjs"
    },
    "./use-locale": {
      "types": "./es/use-locale/index.d.ts",
      "import": "./es/use-locale/index.js",
      "require": "./lib/use-locale/index.cjs"
    }
  },
  "files": [
    "dist",
    "lib",
    "es",
    "README.md"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "lint": "eslint . --max-warnings 0",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:types",
    "build:js": "rollup -c",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist es lib tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:^",
    "@kit/vitest-config": "workspace:^",
    "eslint": "*",
    "rimraf": "*",
    "tsx": "*",
    "typescript": "*"
  },
  "license": "MIT"
}
